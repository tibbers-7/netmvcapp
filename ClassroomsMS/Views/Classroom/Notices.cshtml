@model ClassroomNoticesViewModel
@{
    var c = Model.Classroom;
    var classroomTitle = $"{c.Class.Grade}-{c.Class.ClassNumber} {c.Subject}";
}

<div class="mb-3">
    <a href="javascript:history.back()" class="btn btn-sm btn-outline-secondary">&larr; Back</a>
</div>

<div class="d-flex justify-content-between align-items-start mb-1">
    <h3 class="mb-0">@classroomTitle</h3>
    @if (Model.IsTeacher)
    {
        <span class="badge bg-secondary fs-6 font-monospace">Code: @c.Code</span>
    }
</div>
<p class="text-muted small mb-3">@c.Teacher.User.FirstName @c.Teacher.User.LastName</p>

<ul class="nav nav-tabs mb-4">
    <li class="nav-item">
        <a class="nav-link active" asp-controller="Classroom" asp-action="Notices" asp-route-id="@c.Id">Notices</a>
    </li>
    <li class="nav-item">
        <a class="nav-link" asp-controller="Classroom" asp-action="Tasks" asp-route-id="@c.Id">Tasks</a>
    </li>
    @if (Model.IsTeacher)
    {
        <li class="nav-item">
            <a class="nav-link" asp-controller="Classroom" asp-action="Students" asp-route-id="@c.Id">Students</a>
        </li>
    }
</ul>

@if (Model.IsTeacher)
{
    <div class="mb-4">
        <a asp-controller="Notice" asp-action="Create" asp-route-classroomId="@c.Id" class="btn btn-primary">
            + Add Notice
        </a>
    </div>
}

@if (!c.Notices.Any())
{
    <div class="alert alert-light border">No notices yet.</div>
}

@foreach (var notice in c.Notices)
{
    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <p class="card-text" style="white-space: pre-wrap;">@notice.Text</p>

            @if (notice.Images.Any())
            {
                <div class="d-flex flex-wrap gap-2 mb-2">
                    @foreach (var img in notice.Images)
                    {
                        <a href="@Url.Action("Image", "Notice", new { id = img.Id })" target="_blank">
                            <img src="@Url.Action("Image", "Notice", new { id = img.Id })"
                                 alt="@img.FileName" class="notice-thumb" />
                        </a>
                    }
                </div>
            }

            <small class="text-muted">Posted @notice.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</small>

            @if (Model.IsTeacher)
            {
                <div class="mt-2 d-flex gap-2">
                    <a asp-controller="Notice" asp-action="Edit" asp-route-id="@notice.Id"
                       class="btn btn-sm btn-outline-secondary">Edit</a>
                    <form asp-controller="Notice" asp-action="Delete" asp-route-id="@notice.Id" method="post"
                          onsubmit="return confirm('Delete this notice?')">
                        <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                    </form>
                </div>
            }
        </div>

        <!-- Comments -->
        <div class="card-footer bg-white">
            @foreach (var comment in notice.Comments.OrderBy(cm => cm.CreatedAt))
            {
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <div>
                        <strong class="small">@comment.User.FirstName @comment.User.LastName</strong>
                        <span class="text-muted small ms-2">@comment.CreatedAt.ToLocalTime().ToString("dd MMM HH:mm")</span>
                        <p class="mb-0 small">@comment.Text</p>
                    </div>
                    @if (comment.UserId == Model.CurrentUserId || Model.IsTeacher)
                    {
                        <form asp-controller="Notice" asp-action="DeleteComment" asp-route-id="@comment.Id" method="post">
                            <button type="submit" class="btn btn-sm btn-link text-danger p-0">Delete</button>
                        </form>
                    }
                </div>
            }

            <form asp-controller="Notice" asp-action="AddComment" method="post" class="d-flex gap-2 mt-2">
                <input type="hidden" name="noticeId" value="@notice.Id" />
                <input type="text" name="text" class="form-control form-control-sm" placeholder="Add a comment..." required />
                <button type="submit" class="btn btn-sm btn-primary">Post</button>
            </form>
        </div>
    </div>
}
