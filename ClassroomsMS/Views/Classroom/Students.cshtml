@model ClassroomStudentsViewModel
@{
    var c = Model.Classroom;
    var classroomTitle = $"{c.Class.Grade}-{c.Class.ClassNumber} {c.Subject}";
}

<div class="mb-3">
    <a href="javascript:history.back()" class="btn btn-sm btn-outline-secondary">&larr; Back</a>
</div>

<h3 class="mb-1">@classroomTitle</h3>
<p class="text-muted small mb-3">@c.Teacher.User.FirstName @c.Teacher.User.LastName</p>

<ul class="nav nav-tabs mb-4">
    <li class="nav-item">
        <a class="nav-link" asp-controller="Classroom" asp-action="Notices" asp-route-id="@c.Id">Notices</a>
    </li>
    <li class="nav-item">
        <a class="nav-link" asp-controller="Classroom" asp-action="Tasks" asp-route-id="@c.Id">Tasks</a>
    </li>
    <li class="nav-item">
        <a class="nav-link active" asp-controller="Classroom" asp-action="Students" asp-route-id="@c.Id">Students</a>
    </li>
</ul>

<!-- Classroom Code -->
<div class="card mb-4">
    <div class="card-body d-flex align-items-center gap-3">
        <div>
            <div class="text-muted small">Classroom Code</div>
            <div class="fs-3 fw-bold text-primary font-monospace">@c.Code</div>
        </div>
        <form asp-action="RegenerateCode" asp-route-id="@c.Id" method="post" class="ms-2">
            <button type="submit" class="btn btn-outline-secondary btn-sm"
                    onclick="return confirm('Regenerate code? The old code will stop working.')">
                Regenerate
            </button>
        </form>
    </div>
</div>

<!-- Enrolled Students -->
<h5>Enrolled Students (@c.ClassroomStudents.Count)</h5>
@if (!c.ClassroomStudents.Any())
{
    <p class="text-muted">No students enrolled yet.</p>
}
else
{
    <table class="table table-bordered table-hover mb-4">
        <thead class="table-light">
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Class</th>
                <th>Assign Class</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var cs in c.ClassroomStudents)
            {
                <tr>
                    <td>@cs.StudentUser.User.FirstName @cs.StudentUser.User.LastName</td>
                    <td class="small text-muted">@cs.StudentUser.User.Email</td>
                    <td>
                        @if (cs.StudentUser.Class != null)
                        {
                            @($"{cs.StudentUser.Class.Grade}-{cs.StudentUser.Class.ClassNumber}")
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>
                    <td>
                        <form asp-action="AssignClass" method="post" class="d-flex gap-1">
                            <input type="hidden" name="studentUserId" value="@cs.StudentUser.Id" />
                            <input type="hidden" name="classroomId" value="@c.Id" />
                            <select name="classId" class="form-select form-select-sm" style="width:auto">
                                <option value="">— None —</option>
                                @foreach (var cls in Model.AllClasses)
                                {
                                    <option value="@cls.Id" selected="@(cs.StudentUser.ClassId == cls.Id)">
                                        @cls.Grade-@cls.ClassNumber
                                    </option>
                                }
                            </select>
                            <button type="submit" class="btn btn-sm btn-primary">Set</button>
                        </form>
                    </td>
                    <td>
                        <form asp-action="RemoveStudent" method="post"
                              asp-route-classroomId="@c.Id" asp-route-studentUserId="@cs.StudentUser.Id"
                              onsubmit="return confirm('Remove this student?')">
                            <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<!-- Add Student -->
@if (Model.AvailableStudents.Any())
{
    <h5>Add Student</h5>
    <form asp-action="AddStudent" method="post" class="d-flex gap-2 align-items-center">
        <input type="hidden" name="classroomId" value="@c.Id" />
        <select name="studentUserId" class="form-select" style="max-width: 400px;">
            @foreach (var student in Model.AvailableStudents)
            {
                <option value="@student.Id">
                    @student.User.FirstName @student.User.LastName (@student.User.Email)
                </option>
            }
        </select>
        <button type="submit" class="btn btn-primary">Add</button>
    </form>
}
