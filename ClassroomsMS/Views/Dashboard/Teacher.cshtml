@model TeacherDashboardViewModel

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">My Classrooms</h2>
    <a asp-controller="Classroom" asp-action="Create" class="btn btn-primary">+ New Classroom</a>
</div>

@if (!Model.Classrooms.Any())
{
    <div class="alert alert-info">No classrooms yet. Create your first classroom using the button above.</div>
}
else
{
    <ul class="nav nav-tabs" id="classroomTabs" role="tablist">
        @foreach (var classroom in Model.Classrooms)
        {
            <li class="nav-item" role="presentation">
                <a class="nav-link classroom-tab-link"
                   asp-controller="Classroom" asp-action="Notices" asp-route-id="@classroom.Id">
                    @classroom.Class.Grade-@classroom.Class.ClassNumber @classroom.Subject
                </a>
            </li>
        }
    </ul>
    <div class="border border-top-0 rounded-bottom p-4 bg-white text-muted">
        Select a classroom tab to open it.
    </div>
}
